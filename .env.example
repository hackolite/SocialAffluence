# Google OAuth Configuration
# Get these values from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Redirect URI
# For local development: http://localhost:5000/auth/google/callback
# For Vercel: https://<your-vercel-domain>/auth/google/callback
GOOGLE_REDIRECT_URI=https://your-vercel-domain.vercel.app/auth/google/callback

# Session Secret (change this to a random string in production)
SESSION_SECRET=your_super_secret_session_key_change_this_in_production

# Database Configuration (if using a real database)
# DATABASE_URL=your_database_url_here

# Email / SMTP Configuration (used for the contact form)
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sending_address@gmail.com
SMTP_PASS=your_gmail_app_password
# Destination address for contact form emails
CONTACT_EMAIL=recipient@example.com